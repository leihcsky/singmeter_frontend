{
  "build": {
    "env": {
      "AWS_LAMBDA_JS_RUNTIME": "nodejs22.x",
      "PUPPETEER_SKIP_DOWNLOAD": "true"
    }
  },
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "singmeter.com" }],
      "destination": "https://www.singmeter.com/:path*",
      "permanent": true
    },
    {
      "source": "/blog/vocal-range-vs-voice-type",
      "destination": "/blog/how-to-find-your-voice-type",
      "permanent": true
    },
    {
      "source": "/blog/sing-in-tune-without-piano",
      "destination": "/blog/improve-singing-pitch",
      "permanent": true
    },
    {
      "source": "/blog/use-pitch-detector-for-training",
      "destination": "/blog/improve-singing-pitch",
      "permanent": true
    },
    {
      "source": "/blog/famous-singers-vocal-ranges",
      "destination": "/blog/vocal-range-chart",
      "permanent": true
    },
    {
      "source": "/blog/mixed-voice-vs-head-voice",
      "destination": "/blog/singing-high-notes-techniques",
      "permanent": true
    },
    {
      "source": "/blog/songs-for-your-voice-type",
      "destination": "/blog/how-to-find-your-voice-type",
      "permanent": true
    },
    {
      "source": "/blog/breathing-and-posture-for-singers",
      "destination": "/blog/vocal-health-and-maintenance",
      "permanent": true
    }
  ],
  "rewrites": [{ "source": "/(.*)", "destination": "/index.html" }]
}
