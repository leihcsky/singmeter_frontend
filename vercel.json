{
  "build": {
    "env": {
      "AWS_LAMBDA_JS_RUNTIME": "nodejs22.x",
      "PUPPETEER_SKIP_DOWNLOAD": "true"
    }
  },
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "singmeter.com" }],
      "destination": "https://www.singmeter.com/:path*",
      "permanent": true
    }
  ],
  "rewrites": [{ "source": "/(.*)", "destination": "/index.html" }]
}
